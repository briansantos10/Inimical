import java.io.Console;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.util.Scanner;

public class RestaurantApp {
    static final String DBURL = "jdbc:oracle:thin:@//rocordb01.cse.lehigh.edu:1522/cse241pdb";
    static Scanner scanner = new Scanner(System.in);
    static Console console = System.console();

    public static void main(String[] args) {
        Connection conn = establishConnection();
        if (conn == null) return;

        try (Connection c = conn) {
            runApp(c);
        } catch (SQLException se) {
            System.err.println("Database error: " + se.getMessage());
        }
    }

    static Connection establishConnection() {
        Connection conn = null;
        while (conn == null) {
            String uid  = readLine("Enter Oracle user ID: ");
            String pass = readPassword("Enter Oracle password: ");
            try {
                conn = DriverManager.getConnection(DBURL, uid, pass);
                System.out.println("Connected successfully.\n");
            } catch (SQLException se) {
                System.err.println("Login failed: " + se.getMessage());
            }
        }
        return conn;
    }

    static void runApp(Connection conn) {
        while (true) {
            System.out.println("=== Inimical's Restaurant System ===");
            System.out.println("1. Customer");
            System.out.println("2. Management");
            System.out.println("3. Location Manager");
            System.out.println("4. Exit");
            String choice = readLine("Select: ").trim();

            switch (choice) {
                case "1":
                    new CustomerUI(conn, scanner, console).run();
                    break;
                case "2":
                    new ManagementUI(conn, scanner, console).run();
                    break;
                case "3":
                    new LocationManagerUI(conn, scanner, console).run();
                    break;
                case "4":
                    System.out.println("Goodbye!");
                    return;
                default:
                    System.out.println("Invalid option, try again.\n");
            }
        }
    }

    public static String readLine(String prompt) {
        if (console != null) {
            return console.readLine(prompt);
        } else {
            System.out.print(prompt);
            return scanner.nextLine();
        }
    }

    public static String readPassword(String prompt) {
        if (console != null) {
            return new String(console.readPassword(prompt));
        } else {
            System.out.print(prompt);
            return scanner.nextLine();
        }
    }
}
